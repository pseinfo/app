{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "paths": {
      "@/*": [ "./src/*" ],
      "@/asset/*": [ "./src/assets/*" ],
      "@/c/base/*": [ "./src/components/base/*" ],
      "@/c/ui/*": [ "./src/components/ui/*" ],
      "@/ctx/*": [ "./src/context/*" ],
      "@/hook/*": [ "./src/hooks/*" ],
      "@/layout/*": [ "./src/layouts/*" ],
      "@/lib/*": [ "./src/lib/*" ],
      "@/page/*": [ "./src/pages/*" ],
      "@/provider/*": [ "./src/providers/*" ],
      "@/service/*": [ "./src/services/*" ],
      "@/type/*": [ "./src/types/*" ]
    }
  }
}
