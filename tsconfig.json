{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "paths": {
      "@/*": [ "./src/*" ],
      "@/asset/*": [ "./src/assets/*" ],
      "@/base/*": [ "./src/components/base/*" ],
      "@/ctx/*": [ "./src/context/*" ],
      "@/hook/*": [ "./src/hooks/*" ],
      "@/layout/*": [ "./src/components/layout/*" ],
      "@/lib/*": [ "./src/lib/*" ],
      "@/page/*": [ "./src/pages/*" ],
      "@/type/*": [ "./src/types/*" ],
      "@/ui/*": [ "./src/components/ui/*" ]
    }
  }
}
